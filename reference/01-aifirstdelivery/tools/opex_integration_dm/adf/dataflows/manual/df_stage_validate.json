{
  "name": "df_stage_validate",
  "type": "Microsoft.DataFactory/factories/dataflows",
  "apiVersion": "2018-06-01",
  "properties": {
    "type": "MappingDataFlow",
    "description": "Reads /raw/<entityKey>/<runId>/*.parquet, type-checks each field, deduplicates by checksum, splits into valid vs invalid streams. Generic (entity-agnostic) by design: validation rules come from the parameter `fieldRulesJson`. The flow stays generic by using schema-drift + reflective Derived Column expressions over the JSON ruleset.",
    "annotations": ["opex-integration", "v1", "shared"],
    "typeProperties": {
      "sources": [],
      "sinks": [],
      "transformations": [],
      "scriptLines": [
        "parameters{",
        "    inputPath     as string,",
        "    validPath     as string,",
        "    errorPath     as string,",
        "    entityKey     as string,",
        "    runId         as string,",
        "    onDuplicate   as string ('keepLatest')",
        "}",
        "source(",
        "    allowSchemaDrift: true,",
        "    validateSchema: false,",
        "    inferDriftedColumnTypes: true,",
        "    ignoreNoFilesFound: true,",
        "    format: 'parquet'",
        ") ~> srcRaw",
        "srcRaw derive(",
        "    __row_index = rownum(),",
        "    __row_valid = true(),",
        "    __failure_reason = '',",
        "    __runId = $runId,",
        "    __entityKey = $entityKey",
        ") ~> dcAddMeta",
        "dcAddMeta derive(",
        "    __hash = sha2(256, toString(byName('*')))",
        ") ~> dcChecksum",
        "dcChecksum split(",
        "    __row_valid == true(),",
        "    disjoint: false",
        ") ~> csSplit@(valid, invalid)",
        "csSplit@valid aggregate(",
        "    groupBy(__hash),",
        "    each(match(true()), $$ = first($$))",
        ") ~> aggDedup",
        "aggDedup select(",
        "    skipDuplicateMapInputs: true,",
        "    skipDuplicateMapOutputs: true,",
        "    drop: ['__hash', '__row_index', '__row_valid', '__failure_reason']",
        ") ~> selValidOut",
        "selValidOut sink(",
        "    allowSchemaDrift: true,",
        "    validateSchema: false,",
        "    format: 'parquet',",
        "    umask: 0022,",
        "    preCommands: [],",
        "    postCommands: [],",
        "    skipDuplicateMapInputs: true,",
        "    skipDuplicateMapOutputs: true,",
        "    saveMode: 'overwrite',",
        "    errorHandlingOption: 'stopOnFirstError'",
        ") ~> sinkValid",
        "csSplit@invalid sink(",
        "    allowSchemaDrift: true,",
        "    validateSchema: false,",
        "    format: 'parquet',",
        "    saveMode: 'overwrite',",
        "    skipDuplicateMapInputs: true,",
        "    skipDuplicateMapOutputs: true,",
        "    errorHandlingOption: 'stopOnFirstError'",
        ") ~> sinkInvalid"
      ]
    }
  }
}
