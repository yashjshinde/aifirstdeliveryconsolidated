{
  "name": "tr_wave_oracle_fusion_daily",
  "type": "Microsoft.DataFactory/factories/triggers",
  "properties": {
    "description": "Fires pl_wave_orchestrator(waveKey='oracle_fusion_daily') every day at 02:00 UTC. Set runtimeState to 'Started' after publish to activate.",
    "annotations": ["opex-integration", "v1", "inbound"],
    "runtimeState": "Stopped",
    "pipelines": [
      {
        "pipelineReference": {
          "referenceName": "pl_wave_orchestrator",
          "type": "PipelineReference"
        },
        "parameters": {
          "waveKey": "oracle_fusion_daily",
          "runMode": "incremental"
        }
      }
    ],
    "type": "ScheduleTrigger",
    "typeProperties": {
      "recurrence": {
        "frequency": "Day",
        "interval": 1,
        "startTime": "2026-05-14T02:00:00Z",
        "timeZone": "UTC",
        "schedule": {
          "minutes": [0],
          "hours":   [2]
        }
      }
    }
  }
}
