{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(output/**)",
      "Write(../../templates/**/plans/**)",
      "Write(../../templates/**/tasks/**)",
      "Write(../../templates/**/specs/**)",
      "Write(../../templates/**/docs-generated/**)",
      "Write(../../templates/**/output/**)"
    ]
  },
  "mcpServers": {
    "ado-alm": {
      "command": "node",
      "args": ["ABSOLUTE_PATH_TO_REPO/tools/mcp-server/dist/index.js"],
      "env": {
        "ADO_ORG_URL": "https://dev.azure.com/YOUR-ORG",
        "ADO_PROJECT": "YOUR-PROJECT",
        "ADO_PAT": "YOUR-PAT-HERE"
      }
    }
  }
}
