{
  "name": "spec-driven-dev-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Spec-Driven Development consolidated platform. Modular tool groups: doc_lint, workflow, handoff, config-resolve, alm, converters, brownfield-validators, brownfield-engine, traceability, estimation.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "spec-driven-dev-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "README.md"
  ]
}
